{
  "name": "a5-logo-render",
  "author": "Raoul Zander",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "//=== MAIN — the commands you actually run ===": "",
    "build": "run-s build:*",
    "dev": "run-s dev:build dev:serve",

    "//=== BUILD STEPS — production, run by `build` ===": "",
    "build:css": "run-s css:scss css:autoprefixer",
    "build:js": "webpack --mode=production",
    "build:html": "posthtml -c posthtml.json",
    "build:images": "imagemin src/images/**/* --out-dir=dist/images",
    "//build:images": "with svgo optimisation: imagemin src/images/**/* --out-dir=dist/images --plugin=svgo",

    "//=== DEV — run by `dev`: unminified build, then serve + watch ===": "",
    "dev:build": "run-s build:css dev:js build:html build:images",
    "dev:js": "webpack --mode=development",
    "dev:serve": "run-p serve watch:*",
    "serve": "browser-sync start --server \"dist\" --files \"dist\"",
    "watch:css": "onchange \"src/scss\" -- npm run build:css",
    "watch:js": "onchange \"src/ts\" -- npm run dev:js",
    "watch:html": "onchange \"src/views\" -- npm run build:html",
    "watch:images": "onchange \"src/images\" -- npm run build:images",

    "//=== LOW-LEVEL — single tools, run by the steps above ===": "",
    "css:scss": "sass src/scss/index.scss dist/index.css --style=compressed --load-path=node_modules --no-source-map --quiet-deps",
    "css:autoprefixer": "postcss --no-map -u autoprefixer -r dist/*.css"
  },
  "license": "UNLICENSED",
  "dependencies": {
    "@popperjs/core": "^2.9.1",
    "bootstrap": "5.0.0-beta2",
    "save-svg-as-png": "^1.4.17"
  },
  "devDependencies": {
    "@babel/cli": "^7.20.0",
    "@babel/core": "^7.20.0",
    "@babel/preset-env": "^7.20.0",
    "@babel/preset-typescript": "^7.20.0",
    "@types/bootstrap": "^5.0.8",
    "autoprefixer": "^10.4.0",
    "babel-loader": "^9.0.0",
    "browser-sync": "^3.0.0",
    "eslint": "^7.21.0",
    "htmlnano": "^2.0.0",
    "imagemin-cli": "^8.0.0",
    "imagemin-svgo": "^11.0.0",
    "npm-run-all": "^4.1.5",
    "onchange": "^7.1.0",
    "postcss": "^8.4.0",
    "postcss-cli": "^11.0.0",
    "posthtml": "^0.16.0",
    "posthtml-cli": "^0.10.0",
    "posthtml-inline-svg": "^0.2.0",
    "posthtml-modules": "^0.9.0",
    "sass": "^1.0.0",
    "typescript": "^5.0.0",
    "webpack": "^5.89.0",
    "webpack-cli": "^6.0.0"
  }
}
